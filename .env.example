# Tramontane Environment Variables
# Copy to .env and fill in your values.

# Required
MISTRAL_API_KEY=your_mistral_api_key_here

# Database
TRAMONTANE_DB=tramontane.db

# Environment
TRAMONTANE_ENV=development       # development | production

# Logging
TRAMONTANE_LOG_LEVEL=INFO

# Budget defaults (EUR)
TRAMONTANE_BUDGET_DEFAULT=0.10

# GDPR
TRAMONTANE_GDPR_LEVEL=none       # none | standard | strict
TRAMONTANE_ENFORCE_EU_RESIDENCY=false

# Server
TRAMONTANE_HOST=0.0.0.0
TRAMONTANE_PORT=8080
TRAMONTANE_WORKERS=1
TRAMONTANE_ALLOWED_ORIGINS=*     # comma-separated for production

# Hub (HuggingFace)
HF_TOKEN=hf_...                  # for hub push/pull

# Optional integrations
GITHUB_TOKEN=ghp_...             # MCP GitHub server
E2B_API_KEY=...                  # cloud code sandbox
REDIS_URL=redis://localhost:6379 # optional cache/queue

# Scaleway (production deployment)
SCALEWAY_REGION=fr-par
